{
  "name": "@papitaconpure/booru-client",
  "version": "1.0.0",
  "description": "An extensible, zero-dependency imageboard client with multi-layer tag caching.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "bunx biome lint",
    "lint:fix": "bunx biome lint --write",
    "format": "bunx biome format",
    "format:fix": "bunx biome format --write",
    "dev": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "fix": "bun run lint:fix && bun run format:fix",
    "build": "bun build ./src/index.ts --outdir ./dist --target=node",
    "types": "tsc",
    "prepare": "npm run build && npm run types",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PapitaConPure/booru-client.git"
  },
  "keywords": [
    "gelbooru",
    "nodejs",
    "bun"
  ],
  "author": "PapitaConPure",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PapitaConPure/booru-client/issues"
  },
  "homepage": "https://github.com/PapitaConPure/booru-client#readme"
}
