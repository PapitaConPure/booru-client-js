{
  "name": "@papita/booru-client",
  "version": "0.1.0",
  "description": "A simple Booru wrapper mostly for my personal projects. Uses Node fetch API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target=node",
    "dev": "bun run src/index.ts",
    "types": "tsc",
    "check": "tsc --noEmit",
    "prepublish": "npm run build && npm run types"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^5"
  },
  "dependencies": {
    "bun-types": "^1.3.12",
    "undici-types": "^7.19.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PapitaConPure/booru-client.git"
  },
  "keywords": [
    "gelbooru",
    "nodejs",
    "bun"
  ],
  "author": "PapitaConPure",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PapitaConPure/booru-client/issues"
  },
  "homepage": "https://github.com/PapitaConPure/booru-client#readme"
}
