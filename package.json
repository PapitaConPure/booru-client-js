{
  "name": "@papitaconpure/booru-client",
  "version": "2.0.4",
  "description": "An extensible, zero-dependency imageboard client with multi-layer tag caching.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "bunx biome lint",
    "lint:fix": "bunx biome lint --write",
    "format": "bunx biome format",
    "format:fix": "bunx biome format --write",
    "dev": "bun run src/index.ts",
    "check": "tsc -p tsconfig.build.json --noEmit",
    "fix": "bun run lint:fix && bun run format:fix",
    "build": "bun build ./src/index.ts --outdir ./dist --target=node",
    "types": "tsc -p tsconfig.build.json",
    "preversion": "npm run check",
    "postversion": "git push --follow-tags"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "index.ts",
  "sideEffects": false,
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PapitaConPure/booru-client-js.git"
  },
  "keywords": [
    "bun",
    "nodejs",
    "typescript",
    "danbooru",
    "gelbooru",
    "konachan"
  ],
  "author": "PapitaConPure",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/PapitaConPure/booru-client-js/issues"
  },
  "homepage": "https://github.com/PapitaConPure/booru-client-js#readme"
}
