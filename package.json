{
  "name": "@papitaconpure/booru-fetch",
  "version": "0.1.0",
  "description": "A simple Booru wrapper mostly for my personal projects. Uses Node fetch API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target=node",
    "dev": "bun run src/index.ts",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "index.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "typescript": "^5"
  }
}
